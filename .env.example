# ISMS-Bunny environment (sample; do not use in production as-is)

APP_ENV=development
SECRET_KEY=change-me
JWT_SECRET=change-me-too

DATABASE_URL=postgresql://isms:isms@db:5432/isms
REDIS_URL=redis://cache:6379/0

STORAGE_BACKEND=s3
S3_BUCKET=isms-bunny-dev
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.wasabisys.com
S3_ACCESS_KEY_ID=changeme
S3_SECRET_ACCESS_KEY=changeme

# Enable local MinIO for dev (set to true)
MINIO_ENABLE=false
